<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Устный Русский - Аудио Поиск</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🎧 Устный Русский</h1>
            <p class="subtitle">Поиск и воспроизведение аудиозаписей</p>
        </header>

        <div class="search-container">
            <input type="text" id="searchInput" placeholder="Поиск по имени..." autocomplete="off">
            <span class="search-icon">🔍</span>
        </div>

        <div id="resultsCount" class="results-count"></div>

        <div id="audioList" class="audio-list"></div>

        <div id="playerContainer" class="player-container" style="display: none;">
            <div class="player-header">
                <h3 id="currentTrack">Не выбрано</h3>
                <button id="closePlayer" class="close-btn">✕</button>
            </div>

            <audio id="audioPlayer" preload="metadata"></audio>

            <div class="progress-container">
                <div class="time-display">
                    <span id="currentTime">0:00</span>
                    <span id="duration">0:00</span>
                </div>
                <input type="range" id="progressBar" class="progress-bar" value="0" min="0" max="100" step="0.1">
            </div>

            <div class="controls">
                <button id="rewind" class="control-btn" title="Назад 10 сек">⏪</button>
                <button id="playPause" class="control-btn play-btn">▶️</button>
                <button id="forward" class="control-btn" title="Вперед 10 сек">⏩</button>
            </div>

            <div class="settings">
                <div class="setting-group">
                    <label for="speedControl">Скорость: <span id="speedValue">1.0x</span></label>
                    <input type="range" id="speedControl" min="0.5" max="2" step="0.1" value="1">
                </div>

                <div class="setting-group">
                    <label for="volumeControl">Громкость: <span id="volumeValue">100%</span></label>
                    <input type="range" id="volumeControl" min="0" max="100" step="1" value="100">
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
